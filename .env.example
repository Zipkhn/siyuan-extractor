# Copy to .env and customize. .env is gitignored.

# --- Siyuan kernel API ---
# URL atteignable depuis l'extracteur. Côté Docker compose dev :
# Siyuan tourne sur le service "siyuan" → http://siyuan:6806
# Côté hôte : http://localhost:6806
SIYUAN_URL=http://siyuan:6806

# Token API obtenu dans Siyuan: Settings → About → API token.
# NE PAS exposer côté reader ou client. Server-side only.
SIYUAN_TOKEN=

# --- Webhook security ---
# Doit matcher la valeur configurée dans le plugin (Settings → Publish → Webhook secret).
# Si vide : le webhook accepte tout (à éviter même en dev).
WEBHOOK_SECRET=

# --- HTTP server ---
HOST=0.0.0.0
PORT=3000

# --- Stockage ---
# Racine où l'extracteur écrit les snapshots. Doit être bind-mountée à un volume
# partagé avec le reader (en V1 : volume nommé Docker).
SNAPSHOTS_DIR=/data/snapshots

# --- Comportement ---
# Si "true", produit en plus un fichier <docid>.html sanitisé à côté du JSON.
EMIT_HTML=true

# Niveau de log (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info
