{
    "name": "siyuan-extractor",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Reads published Siyuan documents via bounded API endpoints and emits canonical JSON + sanitized HTML snapshots.",
    "license": "UNLICENSED",
    "author": "Zipkhn",
    "engines": {
        "node": ">=20.10"
    },
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "start": "tsx src/server.ts",
        "build": "tsc",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@fastify/cors": "^10.0.1",
        "cheerio": "^1.0.0",
        "fastify": "^5.2.0",
        "pino": "^9.5.0",
        "pino-pretty": "^11.2.2",
        "sanitize-html": "^2.14.0"
    },
    "devDependencies": {
        "@types/node": "^22.10.5",
        "@types/sanitize-html": "^2.13.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2"
    }
